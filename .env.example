# World Dashboard — Environment Variables
# Copy to .env and fill in your values

# OpenSky Network (OAuth2 client credentials)
# Register at https://opensky-network.org
OPENSKY_CLIENT_ID=your-email@example.com-api-client
OPENSKY_CLIENT_SECRET=your-client-secret

# AISStream.io (WebSocket AIS feed)
# Register at https://aisstream.io
AISSTREAM_API_KEY=your-api-key

# NASA FIRMS (satellite fire data)
# Register at https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=your-map-key
