[Unit]
Description=World Dashboard — Real-Time Global Data Tracker
After=network.target

[Service]
Type=simple
User=ninezerosix
WorkingDirectory=/home/ninezerosix/World Dashboard
EnvironmentFile=/home/ninezerosix/World Dashboard/.env
ExecStart=/usr/bin/python3 -m uvicorn server.app:app --host 0.0.0.0 --port 8080 --workers 1
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Memory limits
MemoryMax=2G
MemorySwapMax=1G

[Install]
WantedBy=multi-user.target
